module update

import project/project
import services/common/response

workflow startup {
  start: Config

  state Config {
    action config/config.Resolve(options: {}) as KueConfig
    on success -> _
    on fail -> Failed
  }

  state Command {
    action project/project.UpdateCommand(command: $command, config: $config.config, flagSet: $config.flagSet, flags: $config.flags) as Result
    on success -> _
    on fail -> Failed
  }

  state Finish {
    action services/common/response.Response(
      value: "<<Result.response??Result??''>>",
      statusCode: 200
    ) as FinalResult
    end ok
  }

  state Failed {
    action services/common/response.Response(
      value: "Failed to execute update command",
      statusCode: 500
    ) as ErrorResult
    end fail
  }
}
