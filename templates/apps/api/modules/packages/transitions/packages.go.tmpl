// UpdateLikes increments or decrements the likes count for a package
func (p *packagesTransitions) UpdateLikes(name, version string, increment bool) (r domain.FlowStepResult) {
	db, err := p.getItemsDB()
	if err != nil {
		r.Success = false
		r.Error = err
		return
	}

	key := fmt.Sprintf("%s@%s", name, version)
	var pkg internal.Package
	if err := db.Get(key, &pkg); err != nil {
		r.Success = false
		r.Error = fmt.Errorf("package not found: %w", err)
		return
	}

	if increment {
		pkg.Analytics.Likes++
	} else if pkg.Analytics.Likes > 0 {
		pkg.Analytics.Likes--
	}
	pkg.Date.UpdatedAt = time.Now().Format(time.RFC3339)

	if err := db.Set(key, pkg); err != nil {
		r.Success = false
		r.Error = fmt.Errorf("failed to update likes: %w", err)
		return
	}

	r.Success = true
	r.Response = map[string]interface{}{
		"package": key,
		"likes":   pkg.Analytics.Likes,
	}
	return
}

