package main

import (
	"flag"
	"fmt"
	"log"
	"os"
	"os/signal"
	"syscall"

	"{{.ProjectName}}/modules"

	"github.com/kuetix/engine"
	"github.com/kuetix/engine/boot"
	"github.com/kuetix/engine/pkg/domain"
)

var Version string
var BuildTime string

func main() {
	amqpURL := flag.String("amqp", "amqp://guest:guest@localhost:5672/", "AMQP connection URL")
	queue := flag.String("queue", "{{.ProjectName}}-queue", "Queue name to consume")
	workflow := flag.String("workflow", "", "Workflow to execute for each message")
	flag.Parse()

	modules.Enable()

	if *workflow == "" {
		fmt.Println("Error: --workflow is required")
		os.Exit(1)
	}

	// Initialize engine environment
	boot.InitializeEnvironment(&boot.Options{
		Version:    Version,
		BuildTime:  BuildTime,
		EngineName: "{{.ProjectName}}-consumer",
		ConfigName: "engine",
		Config:     &domain.Config{},
		Verbose:    true,
	})

	log.Printf("Starting AMQP consumer...")
	log.Printf("  AMQP URL: %s", *amqpURL)
	log.Printf("  Queue: %s", *queue)
	log.Printf("  Workflow: %s", *workflow)

