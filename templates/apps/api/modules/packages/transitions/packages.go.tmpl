type packagesTransitions struct {
	workflow.BaseServiceTransition
	dbm  *jsonDbCache.DB
	pkgs *jsonDbCache.Collection
}

func NewPackagesTransitions() interfaces.ServiceTransitions {
	return &packagesTransitions{}
}

// getItemsDB initializes and returns the database connection
func (p *packagesTransitions) getItemsDB() (*jsonDbCache.Collection, error) {
	if p.pkgs != nil {
		return p.pkgs, nil
	}

	options := p.Ctx.Engine.GetApplication().Env.Options
	dbPath := options.Context["dbPath"].(string)

	// Default path if not provided
	if dbPath == "" {
		dbPath = "./runtime/data"
	}

	// Ensure directory exists
	if err := os.MkdirAll(dbPath, 0755); err != nil {
		return nil, fmt.Errorf("failed to create database directory: %w", err)
	}

	dbFile := filepath.Join(dbPath, "packages")
	db, err := jsonDbCache.NewDB(dbFile)
	if err != nil {
		return nil, fmt.Errorf("failed to initialize database: %w", err)
	}

	p.dbm = db
	p.pkgs = p.dbm.NewCollection("packages")

	return p.pkgs, nil
}

// getOwnerPackages initializes and returns the database connection
func (p *packagesTransitions) getOwnerPackages(userId string) (*internal.OwnerPackages, error) {
	if p.pkgs == nil {
		return nil, fmt.Errorf("package owner database not initialized")
	}

	db := p.pkgs

	packages := internal.OwnerPackages{
		Owner:   "",
		Package: map[string]internal.PackageOwnerMeta{},
	}

	err := db.Get(userId, &packages)
	if err != nil {
		// return nil, fmt.Errorf("failed to get package owner: %w", err)
		return &packages, fmt.Errorf("failed to get package owner: %w", err)
	}

	return &packages, nil
}

// normalizePackageData accepts either the nested internal.Package JSON shape
// (with a "basic" object) or the flat payload the `kue` CLI sends
// ({name, type, description, version, engine, publisher, keywords, modules})
// and returns the nested shape expected by internal.Package.
func normalizePackageData(data map[string]interface{}) map[string]interface{} {
	if data == nil {
		return map[string]interface{}{}
	}
	if _, ok := data["basic"].(map[string]interface{}); ok {
		return data
	}

	str := func(key string) string {
		if s, ok := data[key].(string); ok {
			return strings.TrimSpace(s)
		}
		return ""
	}

	normalized := map[string]interface{}{
		"basic": map[string]interface{}{
			"name":        str("name"),
			"version":     str("version"),
			"description": str("description"),
			"license":     str("license"),
		},
	}
	if publisher := str("publisher"); publisher != "" {
		normalized["authors"] = map[string]interface{}{"author": publisher}
	}
	if keywords, ok := data["keywords"]; ok {
		normalized["categories"] = map[string]interface{}{"keywords": keywords}
	}
	if modules, ok := data["modules"]; ok {
		normalized["modules"] = modules
	}
	if repository := str("repository"); repository != "" {
		normalized["url"] = map[string]interface{}{"repository": repository}
	}
	return normalized
}

// AddPackage adds a new package to the registry
func (p *packagesTransitions) AddPackage(
	data map[string]interface{},
	owner string,
) (r domain.FlowStepResult) {
	db, err := p.getItemsDB()
	if err != nil {
		r.Success = false
		r.Error = err
		return
	}

	// now := time.Now().Format(time.RFC3339)
	pkg := internal.Package{
		Basic: internal.PackageBasic{Owner: owner},
		Status: internal.PackageStatus{
			Status:      "active",
			BuildStatus: "unknown",
		},
		Authors: internal.PackageAuthors{
			Author:       owner,
			Maintainers:  []string{},
			Contributors: nil,
		},
		Categories: internal.PackageCategories{
			Categories: []string{},
			Keywords:   nil,
			Tags:       nil,
		},
		Pricing: internal.PricingTier{
			OneTimePrice:      0,
			SubscriptionPrice: 0,
			CloudPrice:        0,
			EnterprisePrice:   0,
			Currency:          "USD",
		},
	}
	err = mapstructure.Decode(normalizePackageData(data), &pkg)
	if err != nil {
		r.Success = false
		r.Error = fmt.Errorf("failed to unmarshal package data: %w", err)
		return
	}
	pkg.Basic.Owner = owner

	if pkg.Basic.Name == "" || pkg.Basic.Version == "" {
		r.Success = false
		r.StatusCode = 400
		r.Error = fmt.Errorf("package name and version are required")
		return
	}

	now := time.Now().Format(time.RFC3339)
	pkg.Date.CreatedAt = now
	pkg.Date.UpdatedAt = now

	// Versions are immutable: a published (name, version) pair can never be
	// overwritten, only yanked. Report a conflict so clients (kue) can treat
	// it as "already exists".
	key := fmt.Sprintf("%s@%s", pkg.Basic.Name, pkg.Basic.Version)
	var existing internal.Package
	if err = db.Get(key, &existing); err == nil {
		r.Success = false
		r.StatusCode = 409
		r.Error = fmt.Errorf("package %s already exists", key)
		return
	}

	// Store a package with a composite key (name@version)
	if err = db.Set(key, pkg); err != nil {
		r.Success = false
		r.Error = fmt.Errorf("failed to add package: %w", err)
		return
	}

	packages, err := p.getOwnerPackages(owner)
	if err != nil {
		packages = &internal.OwnerPackages{
			Owner:   owner,
			Package: map[string]internal.PackageOwnerMeta{},
		}
	}

	meta := internal.PackageOwnerMeta{
		Owner:      owner,
		Type:       "",
		Name:       "",
		Path:       "",
		Hash:       "",
		Visibility: internal.PackageVisibility{},
		Versions: []internal.PackageOwnerVersion{
			{
				Version:    pkg.Basic.Version,
				Hash:       "",
				Visibility: pkg.Visibility,
			},
		},
	}
	hash := packages.GetVersionFromString(fmt.Sprintf("%s@%s", pkg.Basic.Name, pkg.Basic.Version))
	packages.Package[hash] = meta
	versions := meta
	versions.Hash = uuid.Base64Id(fmt.Sprintf("%s@%s", pkg.Basic.Name, pkg.Basic.Version))
	versions.Versions = append(versions.Versions, internal.PackageOwnerVersion{
		Version:    pkg.Basic.Version,
		Hash:       versions.Hash,
		Visibility: pkg.Visibility,
	})
	versions.Name = pkg.Basic.Name
	versions.Type = pkg.URL.Repository
	versions.Path = pkg.URL.Repository
	versions.Owner = owner
	versions.Visibility = pkg.Visibility
	err = p.pkgs.Set(owner, versions)
	if err != nil {
		r.Success = false
		r.Error = fmt.Errorf("failed to set package versions: %w", err)
		return
	}

	r.Success = true
	r.Response = map[string]interface{}{
		"message": "Package added successfully",
		"package": pkg,
	}
	return
}

