package main

import (
	"encoding/json"
	"flag"
	"fmt"
	"log"
	"net/http"

	"github.com/kuetix/engine"
	"github.com/kuetix/engine/boot"
	"github.com/kuetix/engine/modules"
	"github.com/kuetix/engine/pkg/domain"
)

var Version string
var BuildTime string

type WorkflowRequest struct {
	Workflow string                 `json:"workflow"`
	Args     map[string]interface{} `json:"args"`
}

func main() {
	port := flag.String("port", "8080", "API port")
	flag.Parse()

	modules.Enable()

	// Initialize engine environment
	boot.InitializeEnvironment(&boot.Options{
		Version:    Version,
		BuildTime:  BuildTime,
		EngineName: "{{.ProjectName}}-api",
		ConfigName: "engine",
		Config:     &domain.Config{},
		Verbose:    true,
	})

	http.HandleFunc("/health", healthHandler)
	http.HandleFunc("/workflow/execute", workflowHandler)

	addr := fmt.Sprintf(":%s", *port)
	log.Printf("Starting API server on %s", addr)
	log.Fatal(http.ListenAndServe(addr, nil))
}

func healthHandler(w http.ResponseWriter, r *http.Request) {
	w.Header().Set("Content-Type", "application/json")
	json.NewEncoder(w).Encode(map[string]string{
		"status":  "ok",
		"version": Version,
	})
}

func workflowHandler(w http.ResponseWriter, r *http.Request) {
	if r.Method != http.MethodPost {
		http.Error(w, "Method not allowed", http.StatusMethodNotAllowed)
		return
	}

	var req WorkflowRequest
	if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
		http.Error(w, err.Error(), http.StatusBadRequest)
		return
	}

	response := engine.RunWorkflow(&boot.Options{
		Version:    Version,
		BuildTime:  BuildTime,
		EngineName: "{{.ProjectName}}-api",
		ConfigName: "engine",
		Config:     &domain.Config{},
		Workflow:   req.Workflow,
		Amount:     1,
	})

	w.Header().Set("Content-Type", "application/json")
	json.NewEncoder(w).Encode(response)
}
