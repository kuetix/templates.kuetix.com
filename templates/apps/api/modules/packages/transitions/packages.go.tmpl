// UpdatePackageFromJSON updates an existing package from JSON data
// Note: The owner field from packageData is ignored; the authenticated user becomes the owner
func (p *packagesTransitions) UpdatePackageFromJSON(packageData map[string]interface{}, owner string) (r domain.FlowStepResult) {
	db, err := p.getItemsDB()
	if err != nil {
		r.Success = false
		r.Error = err
		return
	}

	// Parse packageData into Package struct (accepts nested or flat payloads)
	packageData = normalizePackageData(packageData)
	jsonBytes, err := json.Marshal(packageData)
	if err != nil {
		r.Success = false
		r.Error = fmt.Errorf("failed to marshal package data: %w", err)
		return
	}

	var pkg internal.Package = internal.Package{
		Basic: internal.PackageBasic{
			Owner: owner,
		},
		Authors: internal.PackageAuthors{
			Maintainers: nil,
		},
		URL:          internal.PackageURL{},
		Categories:   internal.PackageCategories{},
		Dependencies: internal.PackageDependencies{},
		Analytics:    internal.PackageAnalytics{},
		Status: internal.PackageStatus{
			Status:      "active",
			BuildStatus: "unknown",
		},
		Visibility: internal.PackageVisibility{},
		Quality:    internal.PackageQuality{},
		Pricing:    internal.PricingTier{},
		Date: internal.PackageDate{
			CreatedAt: time.Now().Format(time.RFC3339),
			UpdatedAt: time.Now().Format(time.RFC3339),
		},
		Modules: nil,
	}
	if err := json.Unmarshal(jsonBytes, &pkg); err != nil {
		r.Success = false
		r.Error = fmt.Errorf("failed to unmarshal package data: %w", err)
		return
	}

	// Validate required fields
	if pkg.Basic.Name == "" {
		r.Success = false
		r.Error = fmt.Errorf("package name is required")
		return
	}
	if pkg.Basic.Version == "" {
		r.Success = false
		r.Error = fmt.Errorf("package version is required")
		return
	}

	key := fmt.Sprintf("%s@%s", pkg.Basic.Name, pkg.Basic.Version)
	var existingPkg internal.Package
	if err := db.Get(key, &existingPkg); err != nil {
		r.Success = false
		r.Error = fmt.Errorf("package not found: %w", err)
		return
	}

	// Preserve creation timestamp and set authenticated user as owner
	pkg.Date.CreatedAt = existingPkg.Date.CreatedAt
	pkg.Basic.Owner = owner // Always use authenticated user as owner

	now := time.Now().Format(time.RFC3339)
	pkg.Date.UpdatedAt = now

	// Set defaults for optional fields if not provided
	if pkg.Status.Status == "" {
		pkg.Status.Status = existingPkg.Status.Status
	}
	if pkg.Status.BuildStatus == "" {
		pkg.Status.BuildStatus = existingPkg.Status.BuildStatus
	}
	if pkg.Authors.Maintainers == nil {
		pkg.Authors.Maintainers = existingPkg.Authors.Maintainers
	}
	if pkg.Categories.Categories == nil {
		pkg.Categories.Categories = existingPkg.Categories.Categories
	}
	if pkg.Categories.Tags == nil {
		pkg.Categories.Tags = existingPkg.Categories.Tags
	}
	if pkg.Categories.Keywords == nil {
		pkg.Categories.Keywords = existingPkg.Categories.Keywords
	}
	if pkg.Dependencies.Packages == "" {
		pkg.Dependencies.Packages = existingPkg.Dependencies.Packages
	}
	if pkg.Dependencies.Count == 0 {
		pkg.Dependencies.Count = existingPkg.Dependencies.Count
	}
	if pkg.Dependencies.Count == 0 {
		pkg.Dependencies.Count = existingPkg.Dependencies.Count
	}
	if pkg.Dependencies.DependentsCount == 0 {
		pkg.Dependencies.DependentsCount = existingPkg.Dependencies.DependentsCount
	}
	// Set currency default: use existing if not provided, otherwise default to USD
	if pkg.Pricing.Currency == "" {
		if existingPkg.Pricing.Currency != "" {
			pkg.Pricing.Currency = existingPkg.Pricing.Currency
		} else {
			pkg.Pricing.Currency = "USD"
		}
	}

	// Preserve system-managed fields
	pkg.Visibility.IsPublished = existingPkg.Visibility.IsPublished
	pkg.Analytics.Likes = existingPkg.Analytics.Likes
	pkg.Analytics.Followers = existingPkg.Analytics.Followers
	pkg.Analytics.Downloads = existingPkg.Analytics.Downloads
	pkg.Analytics.Stars = existingPkg.Analytics.Stars
	pkg.Visibility.IsPublished = existingPkg.Visibility.IsPublished
	pkg.Dependencies.DependentsCount = existingPkg.Dependencies.DependentsCount

	// Update dependency count
	pkg.Dependencies.Count = len(pkg.Dependencies.Packages)

	if err := db.Set(key, pkg); err != nil {
		r.Success = false
		r.Error = fmt.Errorf("failed to update package: %w", err)
		return
	}

	r.Success = true
	r.Response = map[string]interface{}{
		"message": "Package updated successfully",
		"package": pkg,
	}
	return
}

// UpdatePackage updates an existing package (for editing)
//
//goland:noinspection GoUnusedParameter
func (p *packagesTransitions) UpdatePackage(
	name, version, description, author, owner, license, repository, homepage, documentation string,
	maintainers, keywords, categories, tags []string,
	dependencies string,
	isPrivate bool,
	status, buildStatus string,
	securityScore, qualityScore int,
	testCoverage float64,
	oneTimePrice, subscriptionPrice, cloudPrice, enterprisePrice float64,
	currency string,
	modules []string,
) (r domain.FlowStepResult) {
	db, err := p.getItemsDB()
	if err != nil {
		r.Success = false
		r.Error = err
		return
	}

	key := fmt.Sprintf("%s@%s", name, version)
	var existingPkg internal.Package
	if err := db.Get(key, &existingPkg); err != nil {
		r.Success = false
		r.Error = fmt.Errorf("package not found: %w", err)
		return
	}

	// Preserve creation timestamp and original owner
	createdAt := existingPkg.Date.CreatedAt
	originalOwner := existingPkg.Basic.Owner
	if owner == "" {
		owner = originalOwner
	}

	now := time.Now().Format(time.RFC3339)

	// Set defaults for optional fields
	if status == "" {
		status = existingPkg.Status.Status
	}
	if buildStatus == "" {
		buildStatus = existingPkg.Status.BuildStatus
	}
	if maintainers == nil {
		maintainers = existingPkg.Authors.Maintainers
	}
	if categories == nil {
		categories = existingPkg.Categories.Categories
	}
	if tags == nil {
		tags = existingPkg.Categories.Tags
	}
	if currency == "" {
		currency = existingPkg.Pricing.Currency
	}
	if currency == "" {
		currency = "USD"
	}
	if modules == nil {
		modules = existingPkg.Modules
	}

	pkg := internal.Package{
		Basic: internal.PackageBasic{
			Name:        name,
			Version:     version,
			Description: description,
			Owner:       owner,
			License:     license,
		},
		Authors: internal.PackageAuthors{
			Author:      author,
			Maintainers: maintainers,
		},
		URL: internal.PackageURL{
			Repository:    repository,
			Homepage:      homepage,
			Documentation: documentation,
		},
		Dependencies: internal.PackageDependencies{
			Packages:        dependencies,
			Count:           len(strings.Split(dependencies, "\n")),
			DependentsCount: existingPkg.Dependencies.DependentsCount, // Preserve dependents count
		},
		Visibility: internal.PackageVisibility{
			IsPrivate:   isPrivate,
			IsPublished: existingPkg.Visibility.IsPublished, // Preserve publish status
		},
		Analytics: internal.PackageAnalytics{
			// Preserve statistics
			Likes:     existingPkg.Analytics.Likes,
			Followers: existingPkg.Analytics.Followers,
			Downloads: existingPkg.Analytics.Downloads,
			Stars:     existingPkg.Analytics.Stars,
		},
		Date: internal.PackageDate{
			// Package metadata
			CreatedAt: createdAt,
			UpdatedAt: now,
			PublishAt: existingPkg.Date.PublishAt, // Preserve publish date
		},
		// Additional fields
		Categories: internal.PackageCategories{
			Keywords:   existingPkg.Categories.Keywords, // Preserve keywords
			Categories: categories,
			Tags:       existingPkg.Categories.Tags, // Preserve tags
		},
		Status: internal.PackageStatus{
			Status:      status,
			BuildStatus: buildStatus,
		},
		Quality: internal.PackageQuality{
			SecurityScore: securityScore,
			QualityScore:  qualityScore,
			TestCoverage:  testCoverage,
		},
		// Pricing information
		Pricing: internal.PricingTier{
			OneTimePrice:      oneTimePrice,
			SubscriptionPrice: subscriptionPrice,
			CloudPrice:        cloudPrice,
			EnterprisePrice:   enterprisePrice,
			Currency:          currency,
		},
		Modules: modules, // Preserve modules field
	}

	if err := db.Set(key, pkg); err != nil {
		r.Success = false
		r.Error = fmt.Errorf("failed to update package: %w", err)
		return
	}

	r.Success = true
	r.Response = map[string]interface{}{
		"message": "Package updated successfully",
		"package": pkg,
	}
	return
}

// SearchPackages searches for packages based on various criteria
//
//goland:noinspection GoUnusedParameter
// packageVisibleTo reports whether a package may appear in search results
// for the given requester. Public+published packages are visible to
// everyone (including anonymous); everything else only to its owner.
func packageVisibleTo(pkg *internal.Package, userId string) bool {
	if pkg.Visibility.IsPublished && !pkg.Visibility.IsPrivate {
		return true
	}
	return userId != "" && pkg.Basic.Owner == userId
}

func (p *packagesTransitions) SearchPackages(
	query, filterPrivate, filterPublished, sortBy, sortOrder string,
	page, pageSize int,
	userId string,
) (r domain.FlowStepResult) {
	db, err := p.getItemsDB()
	if err != nil {
		r.Success = false
		r.Error = err
		return
	}

	// Get all keys
	keys := db.GetAll()

	packages := []internal.Package{}
	queryStr := query

	for _, value := range keys {
		// Parse the value as Package
		var pkg internal.Package
		if err = json.Unmarshal(value, &pkg); err != nil {
			continue
		}

		// Skip owner-meta rows stored in the same collection.
		if pkg.Basic.Name == "" {
			continue
		}

		// Visibility: enforced regardless of the requested filters — filters
		// can only narrow within what the requester may see.
		if !packageVisibleTo(&pkg, userId) {
			continue
		}
		switch filterPrivate {
		case "public":
			if pkg.Visibility.IsPrivate {
				continue
			}
		case "private":
			if !pkg.Visibility.IsPrivate {
				continue
			}
		}
		switch filterPublished {
		case "published", "true":
			if !pkg.Visibility.IsPublished {
				continue
			}
		case "unpublished", "false":
			if pkg.Visibility.IsPublished {
				continue
			}
		}

		// Apply search query
		if queryStr != "" {
			matches := false

			// Search in name
			if pkg.Basic.Name != "" && containsIgnoreCase(pkg.Basic.Name, queryStr) {
				matches = true
			}

			// Search in description
			if !matches && pkg.Basic.Description != "" &&
				containsIgnoreCase(pkg.Basic.Description, queryStr) {
				matches = true
			}

			// Search in author
			if !matches && pkg.Authors.Author != "" &&
				containsIgnoreCase(pkg.Authors.Author, queryStr) {
				matches = true
			}

			// Search in keywords
			if !matches {
				for _, keyword := range pkg.Categories.Keywords {
					if containsIgnoreCase(keyword, queryStr) {
						matches = true
						break
					}
				}
			}

			// Search in categories
			if !matches {
				for _, category := range pkg.Categories.Categories {
					if containsIgnoreCase(category, queryStr) {
						matches = true
						break
					}
				}
			}

			// Search in tags
			if !matches {
				for _, tag := range pkg.Categories.Tags {
					if containsIgnoreCase(tag, queryStr) {
						matches = true
						break
					}
				}
			}

			if !matches {
				continue
			}
		}

		packages = append(packages, pkg)
	}

	// Sort packages
	if sortBy != "" {
		sortPackages(packages, sortBy, sortOrder)
	}

	// Apply pagination
	totalResults := len(packages)
	if page <= 0 {
		page = 1
	}
	if pageSize <= 0 {
		pageSize = 20
	}

	startIdx := (page - 1) * pageSize
	endIdx := startIdx + pageSize

	if startIdx >= totalResults {
		packages = []internal.Package{}
	} else if endIdx > totalResults {
		packages = packages[startIdx:]
	} else {
		packages = packages[startIdx:endIdx]
	}

	totalPages := (totalResults + pageSize - 1) / pageSize

	// Each result keeps the full nested package (pkg.kuetix.com reads
	// basic.*) plus flat name/version/description/publisher keys (the kue
	// CLI reads those).
	results := make([]map[string]interface{}, 0, len(packages))
	for _, pkg := range packages {
		entry := map[string]interface{}{}
		if raw, err := json.Marshal(pkg); err == nil {
			_ = json.Unmarshal(raw, &entry)
		}
		entry["name"] = pkg.Basic.Name
		entry["version"] = pkg.Basic.Version
		entry["description"] = pkg.Basic.Description
		entry["publisher"] = pkg.Authors.Author
		results = append(results, entry)
	}

	r.Success = true
	r.Response = map[string]interface{}{
		"packages":    results,
		"total":       totalResults,
		"page":        page,
		"pageSize":    pageSize,
		"totalPages":  totalPages,
		"hasNextPage": page < totalPages,
		"hasPrevPage": page > 1,
	}
	return
}

// Helper function to check if a string contains another string (case-insensitive)
func containsIgnoreCase(str, substr string) bool {
	if substr == "" || substr == "*" {
		return true
	}

	strLower := ""
	substrLower := ""

	// Convert to lowercase
	strLower = strings.ToLower(str)
	substrLower = strings.ToLower(substr)

	// Check if substr is in str
	if len(substrLower) > len(strLower) {
		return false
	}

	for i := 0; i <= len(strLower)-len(substrLower); i++ {
		if strLower[i:i+len(substrLower)] == substrLower {
			return true
		}
	}

	return false
}

// Helper function to sort packages
func sortPackages(packages []internal.Package, sortBy, sortOrder string) {
	ascending := sortOrder != "desc"

	switch sortBy {
	case "name":
		sort.Slice(packages, func(i, j int) bool {
			if ascending {
				return packages[i].Basic.Name < packages[j].Basic.Name
			}
			return packages[i].Basic.Name > packages[j].Basic.Name
		})
	case "downloads":
		sort.Slice(packages, func(i, j int) bool {
			if ascending {
				return packages[i].Analytics.Downloads < packages[j].Analytics.Downloads
			}
			return packages[i].Analytics.Downloads > packages[j].Analytics.Downloads
		})
	case "likes":
		sort.Slice(packages, func(i, j int) bool {
			if ascending {
				return packages[i].Analytics.Likes < packages[j].Analytics.Likes
			}
			return packages[i].Analytics.Likes > packages[j].Analytics.Likes
		})
	case "followers":
		sort.Slice(packages, func(i, j int) bool {
			if ascending {
				return packages[i].Analytics.Followers < packages[j].Analytics.Followers
			}
			return packages[i].Analytics.Followers > packages[j].Analytics.Followers
		})
	case "createdAt":
		sort.Slice(packages, func(i, j int) bool {
			if ascending {
				return packages[i].Date.CreatedAt < packages[j].Date.CreatedAt
			}
			return packages[i].Date.CreatedAt > packages[j].Date.CreatedAt
		})
	case "updatedAt":
		sort.Slice(packages, func(i, j int) bool {
			if ascending {
				return packages[i].Date.UpdatedAt < packages[j].Date.UpdatedAt
			}
			return packages[i].Date.UpdatedAt > packages[j].Date.UpdatedAt
		})
	default:
		// Default sort by createdAt descending (newest first)
		sort.Slice(packages, func(i, j int) bool {
			return packages[i].Date.CreatedAt > packages[j].Date.CreatedAt
		})
	}
}

// CheckPackageOwnership verifies if a user owns a package
func (p *packagesTransitions) CheckPackageOwnership(repo, version, userID string) (r domain.FlowStepResult) {
	db, err := p.getItemsDB()
	if err != nil {
		r.Success = false
		r.Error = err
		return
	}

	key := fmt.Sprintf("%s@%s", repo, version)
	var pkg internal.Package
	if err := db.Get(key, &pkg); err != nil {
		r.Success = false
		r.Error = fmt.Errorf("package not found: %w", err)
		return
	}

	// Check if user is the owner; ownership violations must fail here because
	// the WSL layer cannot branch on a boolean response at runtime.
	isOwner := pkg.Basic.Owner == userID
	if !isOwner {
		r.Success = false
		r.StatusCode = 403
		r.Error = fmt.Errorf("user %s does not own package %s", userID, key)
		return
	}

	r.Success = true
	r.Response = map[string]interface{}{
		"isOwner": isOwner,
		"owner":   pkg.Basic.Owner,
		"userId":  userID,
	}
	return
}

// GetPackageWithAuth retrieves a package, respecting private/public access
func (p *packagesTransitions) GetPackageWithAuth(name, version, userID string) (r domain.FlowStepResult) {
	db, err := p.getItemsDB()
	if err != nil {
		r.Success = false
		r.Error = err
		return
	}

	key := fmt.Sprintf("%s@%s", name, version)
	var pkg internal.Package
	if err := db.Get(key, &pkg); err != nil {
		r.Success = false
		r.Error = fmt.Errorf("package not found: %w", err)
		return
	}

	// If package is private, check if user is the owner
	if pkg.Visibility.IsPrivate && pkg.Basic.Owner != userID {
		r.Success = false
		r.Error = fmt.Errorf("access denied: package is private")
		return
	}

	r.Success = true
	r.Response = pkg
	return
}
