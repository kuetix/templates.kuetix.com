// GetGlobalStats retrieves aggregated statistics across all packages
func (p *packagesTransitions) GetGlobalStats() (r domain.FlowStepResult) {
	db, err := p.getItemsDB()
	if err != nil {
		r.Success = false
		r.Error = err
		return
	}

	// Get all packages
	keys := db.GetAll()

	var (
		totalPackages   int
		totalLikes      int
		totalFollowers  int
		totalDownloads  int
		totalStars      int
		publicPackages  int
		privatePackages int
		activePackages  int
		mostLiked       []map[string]interface{}
		mostDownloaded  []map[string]interface{}
		mostFollowed    []map[string]interface{}
		recentPackages  []map[string]interface{}
	)

	type PackageWithKey struct {
		Key string
		Pkg internal.Package
	}

	var allPackages []PackageWithKey

	for key, value := range keys {
		var pkg internal.Package
		jsonBytes, err := json.Marshal(value)
		if err != nil {
			continue
		}
		if err := json.Unmarshal(jsonBytes, &pkg); err != nil {
			continue
		}

		allPackages = append(allPackages, PackageWithKey{Key: key, Pkg: pkg})

		totalPackages++
		totalLikes += pkg.Analytics.Likes
		totalFollowers += pkg.Analytics.Followers
		totalDownloads += pkg.Analytics.Downloads
		totalStars += pkg.Analytics.Stars

		if pkg.Visibility.IsPrivate {
			privatePackages++
		} else {
			publicPackages++
		}

		if pkg.Status.Status == "active" {
			activePackages++
		}
	}

	// Get top packages by different metrics
	// Sort and get top 10 most liked
	sortedByLikes := make([]PackageWithKey, len(allPackages))
	copy(sortedByLikes, allPackages)
	sort.Slice(sortedByLikes, func(i, j int) bool {
		return sortedByLikes[i].Pkg.Analytics.Likes > sortedByLikes[j].Pkg.Analytics.Likes
	})
	for i := 0; i < len(sortedByLikes) && i < 10; i++ {
		mostLiked = append(mostLiked, map[string]interface{}{
			"package": sortedByLikes[i].Key,
			"likes":   sortedByLikes[i].Pkg.Analytics.Likes,
			"name":    sortedByLikes[i].Pkg.Basic.Name,
		})
	}

	// Sort and get top 10 most downloaded
	sortedByDownloads := make([]PackageWithKey, len(allPackages))
	copy(sortedByDownloads, allPackages)
	sort.Slice(sortedByDownloads, func(i, j int) bool {
		return sortedByDownloads[i].Pkg.Analytics.Downloads > sortedByDownloads[j].Pkg.Analytics.Downloads
	})
	for i := 0; i < len(sortedByDownloads) && i < 10; i++ {
		mostDownloaded = append(mostDownloaded, map[string]interface{}{
			"package":   sortedByDownloads[i].Key,
			"downloads": sortedByDownloads[i].Pkg.Analytics.Downloads,
			"name":      sortedByDownloads[i].Pkg.Basic.Name,
		})
	}

	// Sort and get top 10 most followed
	sortedByFollowers := make([]PackageWithKey, len(allPackages))
	copy(sortedByFollowers, allPackages)
	sort.Slice(sortedByFollowers, func(i, j int) bool {
		return sortedByFollowers[i].Pkg.Analytics.Followers > sortedByFollowers[j].Pkg.Analytics.Followers
	})
	for i := 0; i < len(sortedByFollowers) && i < 10; i++ {
		mostFollowed = append(mostFollowed, map[string]interface{}{
			"package":   sortedByFollowers[i].Key,
			"followers": sortedByFollowers[i].Pkg.Analytics.Followers,
			"name":      sortedByFollowers[i].Pkg.Basic.Name,
		})
	}

	// Sort by creation date and get 10 most recent
	sortedByDate := make([]PackageWithKey, len(allPackages))
	copy(sortedByDate, allPackages)
	sort.Slice(sortedByDate, func(i, j int) bool {
		return sortedByDate[i].Pkg.Date.CreatedAt > sortedByDate[j].Pkg.Date.CreatedAt
	})
	for i := 0; i < len(sortedByDate) && i < 10; i++ {
		recentPackages = append(recentPackages, map[string]interface{}{
			"package":   sortedByDate[i].Key,
			"name":      sortedByDate[i].Pkg.Basic.Name,
			"createdAt": sortedByDate[i].Pkg.Date.CreatedAt,
		})
	}

	r.Success = true
	r.Response = map[string]interface{}{
		"totalPackages":   totalPackages,
		"totalLikes":      totalLikes,
		"totalFollowers":  totalFollowers,
		"totalDownloads":  totalDownloads,
		"totalStars":      totalStars,
		"publicPackages":  publicPackages,
		"privatePackages": privatePackages,
		"activePackages":  activePackages,
		"mostLiked":       mostLiked,
		"mostDownloaded":  mostDownloaded,
		"mostFollowed":    mostFollowed,
		"recentPackages":  recentPackages,
	}
	return
}

// PublishPackage sets the IsPublished flag to true for a package
func (p *packagesTransitions) PublishPackage(name, version string) (r domain.FlowStepResult) {
	db, err := p.getItemsDB()
	if err != nil {
		r.Success = false
		r.Error = err
		return
	}

	key := fmt.Sprintf("%s@%s", name, version)
	var pkg internal.Package
	if err := db.Get(key, &pkg); err != nil {
		r.Success = false
		r.Error = fmt.Errorf("package not found: %w", err)
		return
	}

	pkg.Visibility.IsPublished = true
	pkg.Date.UpdatedAt = time.Now().Format(time.RFC3339)

	if err := db.Set(key, pkg); err != nil {
		r.Success = false
		r.Error = fmt.Errorf("failed to publish package: %w", err)
		return
	}

	r.Success = true
	r.Response = map[string]interface{}{
		"message":     fmt.Sprintf("Package %s published successfully", key),
		"package":     key,
		"isPublished": pkg.Visibility.IsPublished,
	}
	return
}

