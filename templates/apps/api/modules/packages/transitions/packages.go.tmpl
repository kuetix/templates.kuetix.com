// InstallPackage resolves a package for `kue install`: by exact version when
// given, otherwise the latest version of the named package. The response is
// the package record itself so clients can read its `modules` (Go module
// paths) and dependencies. Visibility is enforced: anonymous requesters (and
// non-owners) can only install public+published packages; invisible packages
// report 404 rather than 403 to avoid leaking their existence.
func (p *packagesTransitions) InstallPackage(name, version, userId string) (r domain.FlowStepResult) {
	if strings.TrimSpace(name) == "" {
		r.Success = false
		r.StatusCode = 400
		r.Error = fmt.Errorf("name is required")
		return
	}

	db, err := p.getItemsDB()
	if err != nil {
		r.Success = false
		r.Error = err
		return
	}

	if version != "" && version != "latest" {
		var pkg internal.Package
		if err := db.Get(fmt.Sprintf("%s@%s", name, version), &pkg); err != nil || !packageVisibleTo(&pkg, userId) {
			r.Success = false
			r.StatusCode = 404
			r.Error = fmt.Errorf("package not found: %s@%s", name, version)
			return
		}
		r.Success = true
		r.StatusCode = 200
		r.Response = pkg
		return
	}

	var latest *internal.Package
	for _, value := range db.GetAll() {
		var pkg internal.Package
		if err := json.Unmarshal(value, &pkg); err != nil {
			continue
		}
		if pkg.Basic.Name != name || !packageVisibleTo(&pkg, userId) {
			continue
		}
		if latest == nil || compareVersions(pkg.Basic.Version, latest.Basic.Version) > 0 {
			cp := pkg
			latest = &cp
		}
	}
	if latest == nil {
		r.Success = false
		r.StatusCode = 404
		r.Error = fmt.Errorf("package not found: %s", name)
		return
	}

	r.Success = true
	r.StatusCode = 200
	r.Response = *latest
	return
}

// GetPackageByModule resolves the registry package that provides the given
// Go module path (as referenced by a workflow action's metadata.go_module).
// Visibility rules match search: anonymous requesters resolve public+published
// packages only; owners also their own. Returns the latest visible version.
func (p *packagesTransitions) GetPackageByModule(module, userId string) (r domain.FlowStepResult) {
	module = strings.TrimSpace(module)
	if module == "" {
		r.Success = false
		r.StatusCode = 400
		r.Error = fmt.Errorf("module is required")
		return
	}

	db, err := p.getItemsDB()
	if err != nil {
		r.Success = false
		r.Error = err
		return
	}

	var latest *internal.Package
	for _, value := range db.GetAll() {
		var pkg internal.Package
		if err := json.Unmarshal(value, &pkg); err != nil {
			continue
		}
		if pkg.Basic.Name == "" || !packageVisibleTo(&pkg, userId) {
			continue
		}
		provides := false
		for _, m := range pkg.Modules {
			if m == module {
				provides = true
				break
			}
		}
		if !provides {
			continue
		}
		if latest == nil || compareVersions(pkg.Basic.Version, latest.Basic.Version) > 0 {
			cp := pkg
			latest = &cp
		}
	}
	if latest == nil {
		r.Success = false
		r.StatusCode = 404
		r.Error = fmt.Errorf("no package provides module %s", module)
		return
	}

	r.Success = true
	r.StatusCode = 200
	r.Response = *latest
	return
}

// compareVersions compares two dotted version strings numerically per
// segment ("1.10.0" > "1.9.9"), falling back to string comparison for
// non-numeric segments. Returns -1, 0, or 1.
func compareVersions(a, b string) int {
	as := strings.Split(strings.TrimPrefix(a, "v"), ".")
	bs := strings.Split(strings.TrimPrefix(b, "v"), ".")
	for i := 0; i < len(as) || i < len(bs); i++ {
		var av, bv string
		if i < len(as) {
			av = as[i]
		}
		if i < len(bs) {
			bv = bs[i]
		}
		ai, aerr := strconv.Atoi(av)
		bi, berr := strconv.Atoi(bv)
		if aerr == nil && berr == nil {
			if ai != bi {
				if ai < bi {
					return -1
				}
				return 1
			}
			continue
		}
		if av != bv {
			if av < bv {
				return -1
			}
			return 1
		}
	}
	return 0
}

// ListPackages lists the authenticated user's own packages (all versions,
// regardless of visibility).
func (p *packagesTransitions) ListPackages(Token jwt.Token) (r domain.FlowStepResult) {
	db, err := p.getItemsDB()
	if err != nil {
		r.Success = false
		r.Error = err
		return
	}

	packages := []internal.Package{}
	for _, value := range db.GetAll() {
		var pkg internal.Package
		if err := json.Unmarshal(value, &pkg); err != nil {
			continue
		}
		// The collection also holds owner-meta rows that unmarshal to empty
		// records — skip anything without a name.
		if pkg.Basic.Name == "" || pkg.Basic.Owner != Token.UserID {
			continue
		}
		packages = append(packages, pkg)
	}

	r.Success = true
	r.Response = packages
	return
}

