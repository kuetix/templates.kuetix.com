}

// ResolveDependencies resolves the dependency tree for a package
func (p *packagesTransitions) ResolveDependencies(name, version string) (r domain.FlowStepResult) {
	db, err := p.getItemsDB()
	if err != nil {
		r.Success = false
		r.Error = err
		return
	}

	// Get the package
	key := fmt.Sprintf("%s@%s", name, version)
	var pkg internal.Package
	if err := db.Get(key, &pkg); err != nil {
		r.Success = false
		r.Error = fmt.Errorf("package not found: %w", err)
		return
	}

	// Resolve dependencies recursively
	resolved := make(map[string]string)
	visited := make(map[string]bool)

	if err := p.resolveDepsRecursive(db, pkg.Dependencies.Packages, resolved, visited); err != nil {
		r.Success = false
		r.Error = err
		return
	}

	r.Success = true
	r.Response = map[string]interface{}{
		"package":      fmt.Sprintf("%s@%s", name, version),
		"dependencies": resolved,
	}
	return
}

// resolveDepsRecursive recursively resolves dependencies
func (p *packagesTransitions) resolveDepsRecursive(db *jsonDbCache.Collection, depPackages string, resolved map[string]string, visited map[string]bool) error {
	deps := strings.Split(depPackages, "\n")
	for _, dep := range deps {
		depParts := strings.Split(dep, "@")
		if len(depParts) != 2 {
			continue
		}
		depName := depParts[0]
		depVersion := depParts[1]
		key := fmt.Sprintf("%s@%s", depName, depVersion)

		// Check for circular dependencies
		if visited[key] {
			continue
		}
		visited[key] = true

		// Add to a resolved list
		resolved[depName] = depVersion

		// Get the dependency package
		var depPkg internal.Package
		if err := db.Get(key, &depPkg); err != nil {
			// Dependency isn't found, but continue
			continue
		}

		// Recursively resolve its dependencies
		if len(depPkg.Dependencies.Packages) > 0 {
			if err := p.resolveDepsRecursive(db, depPkg.Dependencies.Packages, resolved, visited); err != nil {
				return err
			}
		}
	}

	return nil
}

