module {{.ProjectName}}

import services/common

// {{.SolutionNamePascal}} solution - high-level orchestration
solution {{.SolutionName}} {
  start: Setup

  state Setup {
    action services/common/response.ResponseValue(
      value: "{{.SolutionNamePascal}} setup",
      statusCode: 200
    ) as setup_result
    on success -> Execute
  }

  state Execute {
    action services/common/response.ResponseValue(
      value: "{{.SolutionNamePascal}} executing",
      statusCode: 200
    ) as exec_result
    on success -> Finalize
  }

  state Finalize {
    action services/common/response.ResponseValue(
      value: "{{.SolutionNamePascal}} completed",
      statusCode: 200
    ) as result
    end ok
  }
}
